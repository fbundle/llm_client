#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
BIN="$ROOT/bin"
NAME="LLM Agent"

PYINSTALLER="uv run --with pyinstaller pyinstaller"
MAIN="$ROOT/llm_client_window/window.py"
ICON="$ROOT/assets/icon.png"

mkdir -p "$BIN"

case "$(uname -s)" in
    Darwin)
        echo "[build] targeting macOS .app bundle"
        $PYINSTALLER \
            --onefile \
            --windowed \
            --name "$NAME" \
            --icon $ICON \
            --distpath "$BIN" \
            $MAIN
        ;;
    Linux|*)
        echo "[build] targeting Linux binary"
        $PYINSTALLER \
            --onefile \
            --windowed \
            --name "$NAME" \
            --distpath "$BIN" \
            $MAIN
        ;;
esac

echo "[build] done → $BIN"
